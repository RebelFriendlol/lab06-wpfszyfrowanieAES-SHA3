<Window x:Class="CryptoAppWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CryptoAppWpf"
        mc:Ignorable="d"
        Title="Lab 6" Height="600" Width="800">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="AES Encryption/Decryption">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Password:" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="AesPasswordBox" Grid.Row="0" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="Plain Text:" VerticalAlignment="Top" Margin="0,5,0,0"/>
                    <TextBox x:Name="PlainTextTextBox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="Encrypted (Base64):" VerticalAlignment="Top" Margin="0,5,0,0"/>
                    <TextBox x:Name="EncryptedTextBox" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                        <Button x:Name="EncryptTextButton" Content="Encrypt Text" Width="100" Margin="5" Click="EncryptTextButton_Click"/>
                        <Button x:Name="DecryptTextButton" Content="Decrypt Text" Width="100" Margin="5" Click="DecryptTextButton_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="5">
                        <Separator Margin="0,10"/>
                        <TextBlock x:Name="FilePathTextBlockAes" Text="No file selected" Margin="0,5" FontStyle="Italic"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                            <Button x:Name="EncryptFileButton" Content="Encrypt File..." Width="120" Margin="5" Click="EncryptFileButton_Click"/>
                            <Button x:Name="DecryptFileButton" Content="Decrypt File..." Width="120" Margin="5" Click="DecryptFileButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="SHA3-512 Hash">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Input Text:" VerticalAlignment="Top" Margin="0,5,0,0"/>
                    <TextBox x:Name="ShaInputTextBox" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="SHA3-512 Hash:" VerticalAlignment="Center"/>
                    <TextBox x:Name="ShaOutputTextBox" Grid.Row="2" Grid.Column="1" Margin="5" IsReadOnly="True" VerticalAlignment="Center" TextWrapping="Wrap"/>

                    <Button x:Name="HashTextButton" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Content="Generate Hash for Text" Width="180" Margin="5" HorizontalAlignment="Center" Click="HashTextButton_Click"/>

                    <Separator Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10"/>

                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Vertical" Margin="5">
                        <TextBlock x:Name="FilePathTextBlockSha" Text="No file selected" Margin="0,5" FontStyle="Italic"/>
                        <Button x:Name="HashFileButton" Content="Generate Hash for File..." Width="180" Margin="5" HorizontalAlignment="Center" Click="HashFileButton_Click"/>
                        <TextBox x:Name="ShaFileOutputTextBox" Margin="5" IsReadOnly="True" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>